{
  "name": "starvista",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "fetch": "tsx scripts/fetch-repos.ts",
    "snapshot": "tsx scripts/write-snapshot.ts",
    "build:data": "tsx scripts/build-data.ts",
    "data:update": "npm run fetch && npm run snapshot && npm run build:data",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/react": "latest",
    "@astrojs/sitemap": "latest",
    "@octokit/rest": "^22.0.1",
    "astro": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@astrojs/check": "latest",
    "@eslint/js": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "^4.22.4",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
