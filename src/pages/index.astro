---
import RepoExplorer from '../components/RepoExplorer';
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadManifest, loadSnapshots } from '../lib/data';
import { deriveRepoFirstSeenDates } from '../lib/trends';

const manifest = loadManifest();
const snapshots = loadSnapshots();
const firstSeenDates = deriveRepoFirstSeenDates(snapshots);
const today = manifest.generatedAt.slice(0, 10);
const description =
  'A visual discovery surface for high-interest open-source repositories.';
---

<BaseLayout title="StarVista" description={description}>
  <main class="page-shell">
    <header class="site-header">
      <div>
        <h1>StarVista</h1>
        <p>{description}</p>
      </div>
      <a class="source-link" href="https://github.com/MightyKartz/StarVista.git">
        Source
      </a>
    </header>

    <RepoExplorer
      client:load
      repos={manifest.repos}
      baseUrl={import.meta.env.BASE_URL}
      firstSeenDates={firstSeenDates}
      today={today}
    />
  </main>
</BaseLayout>
