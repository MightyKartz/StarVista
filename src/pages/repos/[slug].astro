---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseTimeline from '../../components/ReleaseTimeline.astro';
import Sparkline from '../../components/Sparkline.astro';
import { loadManifest, loadRepoDetails } from '../../lib/data';
import { createEmbedMarkdown, createOgImageUrl } from '../../lib/embed';
import type { Manifest, ManifestRepo } from '../../lib/types';

export function getStaticPaths() {
  const manifest = loadManifest() as Manifest;

  return manifest.repos.map((repo) => ({
    params: { slug: repo.slug },
    props: { repo },
  }));
}

interface Props {
  repo: ManifestRepo;
}

const { repo } = Astro.props;
const details = loadRepoDetails(repo.slug);
const title = `${repo.name} by ${repo.owner} | StarVista`;
const description = repo.description ?? `Visual profile for ${repo.id}.`;
const homeHref = import.meta.env.BASE_URL;
const repoHref = details?.links.repo ?? `https://github.com/${repo.id}`;
const homepageHref = details?.links.homepage;
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site ?? 'https://mightykartz.github.io').toString();
const ogImage = createOgImageUrl(repo, siteUrl);
const embedMarkdown = createEmbedMarkdown(repo, siteUrl);
---

<BaseLayout title={title} description={description} image={ogImage}>
  <main class="page-shell detail-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href={homeHref}>StarVista</a>
      <span aria-hidden="true">/</span>
      <span>{repo.id}</span>
    </nav>

    <section class="detail-hero" style={`--language-color: ${repo.languageColor ?? '#8b949e'}`}>
      <div>
        <p class="detail-hero__owner">{repo.owner}</p>
        <h1>{repo.name}</h1>
        <p>{description}</p>
      </div>
      <div class="detail-actions">
        <a class="source-link" href={repoHref}>GitHub</a>
        {homepageHref && <a class="source-link" href={homepageHref}>Homepage</a>}
      </div>
    </section>

    <section class="detail-stats" aria-label={`${repo.id} statistics`}>
      <div>
        <strong>{repo.stars.toLocaleString('en')}</strong>
        <span>Stars</span>
      </div>
      <div>
        <strong>{repo.forks.toLocaleString('en')}</strong>
        <span>Forks</span>
      </div>
      <div>
        <strong>{repo.openIssues.toLocaleString('en')}</strong>
        <span>Open issues</span>
      </div>
      <div>
        <strong>{repo.activity}</strong>
        <span>Activity</span>
      </div>
    </section>

    {
      details && (
        <>
          <section class="detail-section detail-section--wide">
            <div class="section-heading">
              <h2>Project Snapshot</h2>
              {details.summary.mode === 'llm' && <span class="ai-badge">AI generated</span>}
            </div>
            <p>{details.summary.text}</p>
            {details.readmeExcerpt && <p>{details.readmeExcerpt}</p>}
          </section>

          <section class="detail-panel-grid">
            <div class="detail-section">
              <h2>Languages</h2>
              <div class="language-list" aria-label={`${repo.id} language breakdown`}>
                {Object.entries(details.languages).map(([language, share]) => (
                  <div class="language-list__row">
                    <span>{language}</span>
                    <div class="language-list__track">
                      <span style={`width: ${Math.round(share * 100)}%`} />
                    </div>
                    <strong>{Math.round(share * 100)}%</strong>
                  </div>
                ))}
              </div>
            </div>

            <div class="detail-section">
              <h2>Star History</h2>
              <Sparkline points={details.starHistory} />
            </div>
          </section>

          <section class="detail-section">
            <h2>Recent Releases</h2>
            <ReleaseTimeline releases={details.releases} />
          </section>

          <section class="detail-section">
            <h2>Embed This Card</h2>
            <textarea class="embed-code" readonly rows="3">{embedMarkdown}</textarea>
            <div class="embed-preview">
              <img src={`${import.meta.env.BASE_URL}embed/${repo.slug}.svg`} alt={`${repo.id} StarVista card`} loading="lazy" />
            </div>
          </section>
        </>
      )
    }
  </main>
</BaseLayout>
